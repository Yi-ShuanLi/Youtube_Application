<UserControl
    x:Class="Youtube_Application.Components.ReplyComment.ReplyComment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:Youtube_Application.Components.ReplyComment"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:src="clr-namespace:Youtube_Application.Converters"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <src:BolleanToVisiblity x:Key="booleanConverter" />
        <src:ViewCountToString x:Key="viewCountConverter" />
    </UserControl.Resources>
    <Grid>
        <StackPanel
            Grid.Row="6"
            Height="50"
            Orientation="Horizontal">
            <Image
                Height="45"
                Source="{Binding ImageURL}"
                Stretch="UniformToFill" />
            <TextBox
                x:Name="CommentBox"
                Width="200"
                Text="{Binding Text}">
                <i:Interaction.Triggers>
                    <!--  1. 當取得焦點時 (GotFocus)  -->
                    <i:EventTrigger EventName="GotFocus">
                        <!--  執行你 ViewModel 裡的 Command  -->
                        <i:InvokeCommandAction Command="{Binding FocusCommand}" CommandParameter="GotFocus" />
                    </i:EventTrigger>

                    <!--  2. 當失去焦點時 (LostFocus)  -->
                    <!--
                    <i:EventTrigger EventName="LostFocus">
                    -->
                    <!--  執行你 ViewModel 裡的 Command  -->
                    <!--
                        <i:InvokeCommandAction Command="{Binding FocusCommand}"  CommandParameter="LostFocus"/>
                    </i:EventTrigger>-->
                </i:Interaction.Triggers>
            </TextBox>

            <!--  按鈕容器，記得取名字叫 ButtonPanel  -->
            <StackPanel
                x:Name="ButtonPanel"
                Orientation="Horizontal"
                Visibility="{Binding IsButtonShowBool, Converter={StaticResource booleanConverter}}">
                <Button Command="{Binding ApplyCancelComment}" Content="取消" />
                <Button
                    Command="{Binding ApplyReplyComment}"
                    CommandParameter="{Binding Text}"
                    Content="{Binding ReplyButtonText}" />
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
