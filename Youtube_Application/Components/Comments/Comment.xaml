<UserControl
    x:Class="Youtube_Application.Components.Comments.Comment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Youtube_Application.Components.Comments"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:Youtube_Application.Converters"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BolleanToVisiblity x:Key="booleanConverter" />
        <converters:BolleanNotToVisiblity x:Key="booleanNotConverter" />
        <converters:ViewCountToString x:Key="viewCountConverter" />
        <converters:DateToString x:Key="dateConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Image
                Height="50"
                Source="{Binding AuthorProfileImageUrl}"
                Stretch="UniformToFill" />
        </StackPanel>
        <StackPanel Visibility="{Binding IsEditing , Converter={StaticResource booleanNotConverter}}"
            Grid.Row="1"
            Margin="20,0,0,0"
            Orientation="Horizontal">
            <Label Content="{Binding AuthorDisplayName}" />
            <Label Content="{Binding PublishedAt,Converter={StaticResource dateConverter}}" />
            <Button
                Height="30"
                Content="🖊️編輯"
                Visibility="{Binding IsMyComment}" 
                Command="{Binding OpenEditComment}"/>
            <Button
                Height="30"
                Content="🗑️刪除"
                Visibility="{Binding IsMyComment}" 
                Command="{Binding ApplyDeleteComment}"
                CommandParameter="{Binding Id}"/>
        </StackPanel>
        <StackPanel Visibility="{Binding IsEditing , Converter={StaticResource booleanNotConverter}}"
            Grid.Row="2"
            Margin="20,0,0,0"
            Orientation="Horizontal">
            <Label Content="{Binding TextDisplay}"  />
        </StackPanel>
        <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource booleanConverter}}"
            Grid.Row="3"
            Margin="20,0,0,0"
            Orientation="Horizontal">
            <TextBox Text="{Binding EditText}"  />
            <Button Command="{Binding ApplyCancelComment}" Content="取消" />
            <Button
                Command="{Binding ApplyEditComment}"
                CommandParameter="{Binding }"
                Content="儲存" />
        </StackPanel>
        <StackPanel
            Grid.Row="4"
            Height="50"
            Margin="20,0,0,0"
            Orientation="Horizontal">
            <Label>喜歡人數：</Label>
            <Label Content="{Binding LikeCount}" />
            <Label>我的評價：</Label>
            <Label Content="{Binding ViewerRatingShow}" />
            <Button
                Height="30"
                Margin="20,0,0,0"
                Command="{Binding AddSubComment}"
                CommandParameter="{Binding}"
                Content="回覆" />
        </StackPanel>

    </Grid>
</UserControl>
