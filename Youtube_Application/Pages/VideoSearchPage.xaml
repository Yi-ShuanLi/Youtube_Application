<Page
    x:Class="Youtube_Application.Pages.VideoSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:card="clr-namespace:Youtube_Application.Components.VideoCardComponent"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:filter="clr-namespace:Youtube_Application.Components.SearchFilterComponent"
    xmlns:local="clr-namespace:Youtube_Application.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:page="clr-namespace:Youtube_Application.Components.PaginationComponent"
    Title="VideoSearchPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>




        <filter:SearchFilter Grid.Row="1" FilterCommand="{Binding DataContext.FilterButtonCommand, RelativeSource={RelativeSource AncestorType=Page}}" />

        <ScrollViewer
            Grid.Row="2"
            Margin="0,10,0,0"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <card:VideoCard VideoCardCommand="{Binding DataContext.GetVideoCommand, RelativeSource={RelativeSource AncestorType=Page}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>
        <page:Pagination
            Grid.Row="3"
            CurrentPageCommand="{Binding DataContext.PageChangeCommand, RelativeSource={RelativeSource AncestorType=Page}}"
            TotalCount="{Binding DataContext.TotalResultsCount, RelativeSource={RelativeSource AncestorType=Page}}" />
    </Grid>
</Page>
