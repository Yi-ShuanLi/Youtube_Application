<Window
    x:Class="Youtube_Application.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:filter="clr-namespace:Youtube_Application.Components.SearchFilterComponent"
    xmlns:local="clr-namespace:Youtube_Application"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:page="clr-namespace:Youtube_Application.Components.PaginationComponent"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Label>YouTube ：</Label>
        </StackPanel>


        <filter:SearchFilter Grid.Row="1" FilterCommand="{Binding DataContext.FilterButtonCommand, RelativeSource={RelativeSource AncestorType=Window}}" />

        <ScrollViewer
            Grid.Row="2"
            Margin="0,10,0,0"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Width="220"
                            Height="250"
                            Margin="10"
                            Background="White"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel>
                                <Image
                                    Height="120"
                                    Source="{Binding ImageUrl}"
                                    Stretch="UniformToFill" />
                                <StackPanel Margin="10">
                                    <TextBlock
                                        Height="40"
                                        FontWeight="Bold"
                                        Text="{Binding Title}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="Wrap" />
                                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                        <Ellipse
                                            Width="24"
                                            Height="24"
                                            Margin="0,0,8,0">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding ChannelImageUrl}" Stretch="UniformToFill" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="DimGray"
                                            Text="{Binding ChannelTitle}" />
                                    </StackPanel>
                                    <TextBlock
                                        Margin="0,5,0,0"
                                        FontSize="11"
                                        Foreground="Gray"
                                        Text="{Binding PublishTime, StringFormat=\{0:yyyy/MM/dd\}}" />
                                    <TextBlock
                                        Margin="0,3,0,0"
                                        FontSize="11"
                                        Foreground="DimGray"
                                        Text="{Binding ViewCount}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>
        <page:Pagination
            Grid.Row="3"
            CurrentPageCommand="{Binding DataContext.PageChangeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
            TotalCount="{Binding DataContext.TotalResultsCount, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Grid>
</Window>